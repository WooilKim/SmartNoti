<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!--
            DebugInjectNotificationReceiver — debug APK only.

            Accepts an `am broadcast` from the journey-tester priority-inbox
            recipe and posts a real Notification whose `extras` bundle carries
            the `com.smartnoti.debug.FORCE_STATUS` sentinel. The listener's
            standard `onNotificationPosted` pipeline then picks it up and the
            `DebugClassificationOverride` resolver pins the classification
            regardless of accumulated user rules on the emulator.

            This receiver lives under `app/src/debug/`, so it is never merged
            into release APKs (plan
            `docs/plans/2026-04-22-priority-recipe-debug-inject-hook.md`).
        -->
        <receiver
            android:name=".debug.DebugInjectNotificationReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.smartnoti.debug.INJECT_NOTIFICATION" />
            </intent-filter>
        </receiver>

        <!--
            DebugBootstrapRehearsalReceiver — debug APK only.

            Accepts an `am broadcast` from the journey-tester
            onboarding-bootstrap non-destructive sub-recipe and re-runs the
            production bootstrap pipeline against the listener's currently
            active notifications without consulting the one-shot pending
            flag. Lets the recipe verify the bootstrap path on every
            rotation tick without `pm clear` (which would also wipe the
            NotificationListener permission grant).

            This receiver lives under `app/src/debug/`, so it is never
            merged into release APKs. Plan:
            `docs/plans/2026-04-27-onboarding-bootstrap-non-destructive-recipe.md`.
        -->
        <receiver
            android:name=".debug.DebugBootstrapRehearsalReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.smartnoti.debug.REHEARSE_BOOTSTRAP" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
